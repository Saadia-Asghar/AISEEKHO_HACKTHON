{
  "expo": {
    "name": "KhidmatAI",
    "slug": "khidmat-ai",
    "version": "2.0.0",
    "scheme": "khidmatai",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "web": {
      "bundler": "metro",
      "output": "single",
      "backgroundColor": "#0A0A0F"
    },
    "splash": {
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "bundleIdentifier": "com.khidmatai.app"
    },
    "android": {
      "package": "com.khidmatai.app",
      "adaptiveIcon": {
        "backgroundColor": "#7C3AED"
      }
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-av",
        {
          "microphonePermission": "KhidmatAI needs the microphone for voice booking (Google speech)."
        }
      ]
    ]
  }
}
