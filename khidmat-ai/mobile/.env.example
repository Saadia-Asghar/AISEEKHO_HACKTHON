# Local backend (simulator / web)
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000

# Physical device on same Wi‑Fi — use your PC LAN IP, e.g.:
# EXPO_PUBLIC_API_URL=http://192.168.1.42:8000

# Production API after deploy:
# EXPO_PUBLIC_API_URL=https://api.yourdomain.com

# Clerk phone OTP (real SMS). Omit for demo OTP 1234.
# EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxx

# Optional: real map tiles on Results (Google Static Maps). Web works without this via OpenStreetMap.
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_maps_key
